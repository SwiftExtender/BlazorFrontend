@using Demo.Models;
@using System.Net.Http.Json;
@inject HttpClient Http





@code {
    [Parameter]
    public List<Site> SitesList {get; set;} = new List<Site>();
    private async Task EditDomain() {
        Site? editDomainRequest = await Http.GetFromJsonAsync<Site>("http://127.0.0.1:4108/api/sites/edit");
    }
    private async Task DeletePort(Site site) {
        await Http.PostAsJsonAsync("http://127.0.0.1:4108/api/sites/delete", site.Id); 
    }
}