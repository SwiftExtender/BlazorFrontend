@using Demo.Models;
@using System.Net.Http.Json;
@inject HttpClient Http

<button class="add-button" @onclick="CreatePortForm">Create Port</button>

@foreach (Port port in PortsList)
                        {<div class="port-form-box"><EditForm class="port-form" Model="@port" OnSubmit="() => SavePort(port)" FormName="PortForm">
                            <div>
                                <label>
                                Number
                                <input type="number" @bind="port.Number" @bind:event="oninput"></input>
                                </label>
                            </div>
                            <div>
                                <label>
                                Info
                                <input type="text" @bind="port.Info" @bind:event="oninput"></input>
                                </label>
                            </div>
                            <div>
                                <label>
                                Protocol
                                <input type="text" @bind="port.Protocol" @bind:event="oninput"></input>
                                </label>
                            </div>
                            <div>
                                <label>
                                Banner
                                <input type="text" @bind="port.Banner" @bind:event="oninput"></input>
                                </label>
                            </div>
                            <input type="hidden" @bind="port.Id"/>
                            <div>
                                <button type="submit" >Save</button>
                                <button type="button btn-danger" @onclick="() => DeletePort(port)">Detach</button>
                            </div>
                         </EditForm></div>}

@code {
    //@onclick="() => SavePort(port)"
    [Parameter]
    public List<Port> PortsList {get; set;} = new List<Port>();

    [Parameter]
    public int RelatedHost {get; set;} = 0;

    private async Task CreatePortForm() {
        PortsList.Add(new Port {Number = 0, Info = String.Empty, Banner = String.Empty, HostId = RelatedHost, Protocol = "tcp"});
    }
    private async Task SavePort(Port newPort) {
        await Http.PostAsJsonAsync<Port>("http://127.0.0.1:4108/api/ports/save", newPort);
    }
    private async Task DeletePort(Port port) {
        await Http.PostAsJsonAsync("http://127.0.0.1:4108/api/ports/delete", port.Id);
        PortsList.Remove(port);
    }
}