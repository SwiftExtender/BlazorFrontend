@using Demo.Models;
@using System.Net.Http.Json;
@inject HttpClient Http

<button class="add-button" @onclick="CreatePortForm">Create Port</button>

@foreach (Port port in PortsList)
                        {<div class="form-box-@(port.State == FormState.TEMP ? "temp" : port.State == FormState.EDITED ? "edited" : "")"><EditForm class="port-form" Model="@port" FormName="PortForm">
                            <div class="textarea-box">
                                <p class="label-text">Number</p>
                                <input type="number" @bind="port.Number" @oninput="() => OnInputHandler(port)"></input>
                            </div>
                            <div class="textarea-box">
                                <p class="label-text">Info</p>
                                <textarea type="text" @bind="port.Info" @oninput="() => OnInputHandler(port)"></textarea>
                            </div>
                            <div class="textarea-box">
                                <p class="label-text">Protocol</p>
                                <input type="text" @bind="port.Protocol" @oninput="() => OnInputHandler(port)"></input>
                            </div>
                            <div class="textarea-box">
                                <p class="label-text">Banner</p>
                                <textarea type="text" @bind="port.Banner" @oninput="() => OnInputHandler(port)"></textarea>
                            </div>
                            <input type="hidden" @bind="port.Id"/>
                            <div>
                                <button type="submit" class="save-button" @onclick="() => SavePortProcess(port)">Save</button>
                                <button type="button" class="delete-button" @onclick="() => DeletePort(port)">Detach</button>
                            </div>
                         </EditForm></div>
}

@code {
    [Parameter]
    public List<Port> PortsList {get; set;} = new List<Port>();

    [Parameter]
    public int RelatedHost {get; set;} = 0;

    private async Task CreatePortForm() {
        PortsList.Add(new Port {Number = 0, Info = String.Empty, Banner = String.Empty, HostId = RelatedHost, Protocol = "tcp", State = FormState.TEMP});
    }
    private async Task EditPort(Port newPort) {
        await Http.PostAsJsonAsync<Port>("http://127.0.0.1:4108/api/ports/edit", newPort);
        newPort.State = FormState.SAVED;
        StateHasChanged();
    }
    private async Task CreatePort(Port newPort) {
        HttpResponseMessage? createdPortResponse = await Http.PostAsJsonAsync<Port>("http://127.0.0.1:4108/api/ports/create", newPort);
        if (createdPortResponse.IsSuccessStatusCode) {
            Port createdPort = await createdPortResponse.Content.ReadFromJsonAsync<Port>();
            newPort.Id = createdPort.Id;
        }
        newPort.State = FormState.SAVED;
        StateHasChanged();
    }

    private async Task SavePortProcess(Port savePort) {
        if (savePort.State == FormState.TEMP) {
            await CreatePort(savePort);
        } else {
            await EditPort(savePort);
        }
    }

    private async Task DeletePort(Port port) {
        if (port.State != FormState.TEMP) {
            await Http.PostAsJsonAsync("http://127.0.0.1:4108/api/ports/delete", port);
        }
        PortsList.Remove(port);
    }
    private void OnInputHandler(Port port) {
        if (port.State == FormState.SAVED) {
            port.State = FormState.EDITED;
            StateHasChanged();
        }
    }
}