@page "/explore"
@using System.Net.Http.Json
@using Demo.Components;
@using Demo.Models;
@inject HttpClient Http

<h3>Explore</h3>

@if (isLoading)
{
    <p><em>Loading data...</em></p>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <p class="text-danger">Error loading data: @errorMessage</p>
}
else
{
    <table class="table-custom table-striped">
        <thead class="table-custom-head">
            <tr>
                <th>Id</th>
                <th>Ip</th>
                <th>SubnetId</th>
                <th>Subnet</th>
                <th>Info</th>
                <th>Domains</th>
                <th>Ports</th>
                <th>Tags</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var host in hosts.hosts)
            {
                <tr>
                    <td>@host.Id</td>
                    <td>@host.Ip</td>
                    <td>@host.SubnetId</td>
                    <td>@host.Subnet</td>
                    <td>@host.Info</td>
                    <td>
                        <DomainForm DomainsList=host.Domains></DomainForm>
                    </td>
                    <td>
                        <PortForm PortsList="host.Ports" RelatedHost="host.Id"></PortForm>
                    </td>
                    <td>
                        <TagForm TagsList="host.Tags"></TagForm>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private Hosts hosts;
    private bool isLoading = true;
    private string errorMessage;
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Fetch and automatically deserialize the JSON into a List<User>
            hosts = await Http.GetFromJsonAsync<Hosts>("http://127.0.0.1:4108/api/explore");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
   
}