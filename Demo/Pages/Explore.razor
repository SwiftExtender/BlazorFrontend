@page "/explore"
@using System.Net.Http.Json
@inject HttpClient Http

<h3>Explore</h3>

@if (isLoading)
{
    <p><em>Loading data...</em></p>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <p class="text-danger">Error loading data: @errorMessage</p>
}
else
{
    <table class="table-custom table-striped">
        <thead class="table-custom-head">
            <tr>
                <th>Id</th>
                <th>Ip</th>
                <th>SubnetId</th>
                <th>Subnet</th>
                <th>Info</th>
                <th>Domains</th>
                <th>Ports</th>
                <th>Tags</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var host in hosts.hosts)
            {
                <tr>
                    <td>@host.Id</td>
                    <td>@host.Ip</td>
                    <td>@host.SubnetId</td>
                    <td>@host.Subnet</td>
                    <td>@host.Info</td>
                    <td>
                        @foreach (Domain d in @host.Domains)
                        {<div class="domain-form-box"><EditForm class="domain-form" Model="d" OnSubmit="EditDomain" FormName="DomainForm">
                            <div>
                                <label>
                                Name
                                <InputText @bind-Value="d.Name"></InputText>
                                </label>
                            </div>
                            <div>
                                <label>
                                Info
                                <InputText @bind-Value="d.Info"></InputText>
                                </label>
                            </div>
                            <input type="hidden" @bind-value="d.Id"/>
                            <div>
                                <button type="btn-success">Save</button>
                                <button type="btn-danger" @onclick="DetachDomain">Detach</button>
                            </div>
                         </EditForm>
                         </div>}
                    </td>
                    <td>@foreach (Port port in @host.Ports)
                        {<div class="port-form-box"><EditForm class="port-form" Model="port" OnSubmit="EditPort" FormName="PortForm">
                            <div>
                                <label>
                                Number
                                <InputNumber @bind-Value="port.Number"></InputNumber>
                                </label>
                            </div>
                            <div>
                                <label>
                                Info
                                <InputText @bind-Value="port.Info"></InputText>
                                </label>
                            </div>
                            <div>
                                <label>
                                Protocol
                                <InputText @bind-Value="port.Protocol"></InputText>
                                </label>
                            </div>
                            <div>
                                <label>
                                Banner
                                <InputText @bind-Value="port.Banner"></InputText>
                                </label>
                            </div>
                            <input type="hidden" @bind-value="port.Id"/>
                            <div>
                                <button type="submit">Save</button>
                                <button type="button btn-danger" @onclick="DetachPort">Detach</button>
                            </div>
                         </EditForm></div>}
                    </td>
                    <td>@foreach (Tag tag in @host.Tags)
                        {
                            <div class="tag-form"><EditForm Model="tag" OnSubmit="EditTag" FormName="TagForm">
                            <div>
                                <label>
                                Number
                                <InputNumber @bind-Value="tag.Name"></InputNumber>
                                </label>
                            </div>
                            <input type="hidden" @bind-value="tag.Id"/>
                            <div>
                                <button type="submit">Save</button>
                                <button type="button btn-danger" @onclick="DetachTag">Detach</button>
                            </div>
                         </EditForm></div>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private Hosts hosts;
    private bool isLoading = true;
    private string errorMessage;
    private async Task EditDomain() {
        Domain? editDomainRequest = await Http.GetFromJsonAsync<Domain>("/api/domains/edit");
    }
    private void DetachDomain() {

    }
    private async Task EditPort() {
        Port? editPortRequest = await Http.GetFromJsonAsync<Port>("/api/ports/edit");
    }
    private void DetachPort() {

    }
    private async Task EditTag() {

    }
    private void DetachTag() {

    }
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Fetch and automatically deserialize the JSON into a List<User>
            hosts = await Http.GetFromJsonAsync<Hosts>("http://127.0.0.1:4108/api/explore");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
    public class Hosts
    {
        public List<Host> hosts { get; set; }
    }
    // C# Model matching the JSON structure
    public class Host
    {
        public int Id { get; set; }
        public string Ip { get; set; }
        public string SubnetId { get; set; }
        public string Subnet { get; set; }
        public string Info { get; set; }
        public List<Domain> Domains { get; set; }
        public List<Port> Ports { get; set; }
        public List<Tag> Tags { get; set; }
    }
    public class Tag {
        public int Id { get; set; }
        public string Name { get; set; }
        public string? Info { get; set; }
    }
    public class Port {
        public int Id { get; set; }
        public int Number { get; set; }
        public string? Info { get; set; }
        public int HostId { get; set; } 
        public string Protocol { get; set; }
        public string? Banner { get; set; }
    }
    public class Domains {
        public List<Domain> domains { get; set; }
    }
    public class Domain {
        public int Id { get; set; }

        public string Name { get; set; }

        public string? Info { get; set; }
    }
}